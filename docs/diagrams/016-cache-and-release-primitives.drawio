                <mxCell id="title" value="CacheAndRelease &amp; Extractor — Buffering Primitives" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=20" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="2000" height="36" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="Bounded streaming buffer with a release decision. Used by both Codecs and Transforms.  Companion to 015.  See docs/adrs/016-cache-and-release-primitives.md." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=2;fontSize=12" parent="1" vertex="1">
                    <mxGeometry x="40" y="58" width="2000" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="motiv-box" value="Today: three open-coded implementations of essentially the same primitive — no shared machinery." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8" parent="1" vertex="1">
                    <mxGeometry x="40" y="100" width="2000" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="motiv-1" value="MarkerScanner FSM&#xa;byte-level held-bytes state&#xa;hard 64-byte cap&#xa;releases verbatim on overflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="1" vertex="1">
                    <mxGeometry x="60" y="130" width="320" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="motiv-2" value="noodle-proxy::sse frame parser&#xa;raw body byte buffer&#xa;searches for \n\n terminator&#xa;no explicit cap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="1" vertex="1">
                    <mxGeometry x="400" y="130" width="320" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="motiv-3" value="Per-vendor StreamingDecoder&#xa;event:/data: pair buffering&#xa;cross-frame state for typed SSE&#xa;trusts upstream framing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="1" vertex="1">
                    <mxGeometry x="740" y="130" width="320" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="motiv-arrow" value="" style="endArrow=classic;html=1;strokeColor=#d79b00;strokeWidth=3" parent="1" edge="1">
                    <mxGeometry as="geometry">
                        <mxPoint x="1080" y="170" as="sourcePoint"/>
                        <mxPoint x="1200" y="170" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="motiv-unify" value="unify into one trait" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;fontStyle=2" parent="1" vertex="1">
                    <mxGeometry x="1080" y="148" width="120" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="motiv-trait" value="CacheAndRelease&lt;E&gt;&#xa;cache · poll_release · flush · policy()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="1220" y="138" width="320" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="motiv-bounds" value="four explicit bounds&#xa;max_bytes · max_wall_ms&#xa;min_release_chunk · on_overflow" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="1560" y="138" width="200" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="motiv-audit" value="overflow audits as first-class events" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="1780" y="138" width="200" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="layer-trait" value="CacheAndRelease&lt;E&gt; — the low-level primitive" style="swimlane;startSize=28;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;horizontal=1" parent="1" vertex="1">
                    <mxGeometry x="40" y="240" width="2000" height="320" as="geometry"/>
                </mxCell>
                <mxCell id="t-api" value="API surface" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1" parent="layer-trait" vertex="1">
                    <mxGeometry x="20" y="38" width="160" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="t-api-code" value="type Event;&#xa;&#xa;fn cache(&amp;mut self, event: Event);&#xa;fn poll_release(&amp;mut self) -&gt; Vec&lt;Event&gt;;&#xa;fn flush(&amp;mut self, reason: FlushReason) -&gt; Vec&lt;Event&gt;;&#xa;&#xa;fn buffered_bytes() -&gt; usize;&#xa;fn deadline() -&gt; Option&lt;Instant&gt;;&#xa;fn policy() -&gt; CacheAndReleasePolicy;" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Courier New;fontSize=10;spacingLeft=8;spacingTop=4" parent="layer-trait" vertex="1">
                    <mxGeometry x="20" y="62" width="500" height="190" as="geometry"/>
                </mxCell>
                <mxCell id="t-policy-title" value="CacheAndReleasePolicy" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1" parent="layer-trait" vertex="1">
                    <mxGeometry x="540" y="38" width="280" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="t-policy-bytes" value="max_bytes" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;align=center;verticalAlign=middle" parent="layer-trait" vertex="1">
                    <mxGeometry x="540" y="62" width="140" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="t-policy-bytes-desc" value="hard memory ceiling.&#xa;Exceeding → OverflowBehavior fires." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10" parent="layer-trait" vertex="1">
                    <mxGeometry x="690" y="62" width="280" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="t-policy-wall" value="max_wall_ms" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;align=center;verticalAlign=middle" parent="layer-trait" vertex="1">
                    <mxGeometry x="540" y="104" width="140" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="t-policy-wall-desc" value="age cap for oldest buffered event.&#xa;Exceeding → FlushReason::Deadline." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10" parent="layer-trait" vertex="1">
                    <mxGeometry x="690" y="104" width="280" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="t-policy-chunk" value="min_release_chunk" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;align=center;verticalAlign=middle" parent="layer-trait" vertex="1">
                    <mxGeometry x="540" y="146" width="140" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="t-policy-chunk-desc" value="release granularity — prevents&#xa;pathological &quot;emit one at a time&quot; pattern." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10" parent="layer-trait" vertex="1">
                    <mxGeometry x="690" y="146" width="320" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="t-policy-overflow" value="on_overflow:&#xa;OverflowBehavior" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;align=center;verticalAlign=middle" parent="layer-trait" vertex="1">
                    <mxGeometry x="540" y="188" width="140" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="t-overflow-options" value="ReleaseVerbatim&#xa;DropAndAudit&#xa;Replace(placeholder)&#xa;FailFlow" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontFamily=Courier New;fontSize=10" parent="layer-trait" vertex="1">
                    <mxGeometry x="690" y="184" width="200" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="t-flush-title" value="FlushReason — every non-trivial drain carries one" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1" parent="layer-trait" vertex="1">
                    <mxGeometry x="1040" y="38" width="500" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="t-flush-1" value="Triggered&#xa;normal decision; emit decided output" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8" parent="layer-trait" vertex="1">
                    <mxGeometry x="1040" y="62" width="380" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="t-flush-2" value="Deadline&#xa;max_wall_ms exceeded — release what we have + audit" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8" parent="layer-trait" vertex="1">
                    <mxGeometry x="1040" y="110" width="380" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="t-flush-3" value="MaxBuffer&#xa;max_bytes exceeded — apply OverflowBehavior + audit" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8" parent="layer-trait" vertex="1">
                    <mxGeometry x="1040" y="158" width="380" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="t-flush-4" value="EndOfStream&#xa;flow ended (normal or aborted)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8" parent="layer-trait" vertex="1">
                    <mxGeometry x="1040" y="206" width="380" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="t-ref-impl" value="Reference impl: BoundedCacheAndRelease&lt;E&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="layer-trait" vertex="1">
                    <mxGeometry x="1440" y="62" width="540" height="190" as="geometry"/>
                </mxCell>
                <mxCell id="t-ref-impl-desc" value="• deque&lt;E&gt; for the buffer&#xa;• running byte counter&#xa;• per-buffer-span Instant for deadline&#xa;• policy validated at construction&#xa;• overflow always audits via AuditEvent::CacheAndReleaseOverflow&#xa;&#xa;~150 lines of code; ~10 tests covering each FlushReason and each&#xa;OverflowBehavior variant.&#xa;&#xa;Default impl used by 80% of consumers — fall back to a custom&#xa;CacheAndRelease only for performance-critical FSMs (e.g. byte&#xa;level marker scanner over &amp;[u8])." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;spacingLeft=12;spacingTop=28" parent="layer-trait" vertex="1">
                    <mxGeometry x="1440" y="62" width="540" height="190" as="geometry"/>
                </mxCell>
                <mxCell id="t-audit-title" value="Audit semantics — non-negotiable" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1" parent="layer-trait" vertex="1">
                    <mxGeometry x="20" y="262" width="500" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="t-audit-desc" value="Every non-Triggered flush emits AuditEvent { kind: CacheAndReleaseOverflow, policy, buffer_at_flush, age_at_flush_ms, reason, on_overflow_action }. Operators tail with jq, see which transforms are sized wrong for real traffic, tune policy without code change. Silent overflow is the failure mode that bites you in production." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10" parent="layer-trait" vertex="1">
                    <mxGeometry x="20" y="284" width="1960" height="32" as="geometry"/>
                </mxCell>
                <mxCell id="layer-extractor" value="Extractor&lt;E&gt; — higher-order policy over a CacheAndRelease" style="swimlane;startSize=28;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;horizontal=1" parent="1" vertex="1">
                    <mxGeometry x="40" y="580" width="2000" height="360" as="geometry"/>
                </mxCell>
                <mxCell id="ex-api-title" value="Trait shape" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1" parent="layer-extractor" vertex="1">
                    <mxGeometry x="20" y="38" width="160" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="ex-api-code" value="trait Extractor {&#xa;    type Event;&#xa;    type Captured;&#xa;    fn observe(&amp;mut self,&#xa;        event: &amp;Event,&#xa;        buffered: &amp;Buffered&lt;Event&gt;,&#xa;    ) -&gt; ExtractorOutcome&lt;Captured&gt;;&#xa;}&#xa;&#xa;enum ExtractorOutcome&lt;T&gt; {&#xa;    Pending,&#xa;    Captured { value: T,&#xa;               action: ExtractionAction },&#xa;}&#xa;&#xa;enum ExtractionAction {&#xa;    Tap,&#xa;    Strip(BufferRange),&#xa;    Replace(BufferRange,&#xa;            ReplacementEvent),&#xa;}" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Courier New;fontSize=10;spacingLeft=8;spacingTop=4" parent="layer-extractor" vertex="1">
                    <mxGeometry x="20" y="62" width="380" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="ex-spec-title" value="Four specialized extractors — cover ~80% of use cases" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1" parent="layer-extractor" vertex="1">
                    <mxGeometry x="420" y="38" width="500" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="ex-literal" value="LiteralPatternExtractor&#xa;Find content delimited by configurable open/close (e.g. &lt;noodle:NAME&gt;...&lt;/noodle:NAME&gt;).&#xa;Today&#39;s MarkerScanner generalized.&#xa;&#xa;use cases: structured markers, XML-ish payloads, fixed-delimiter capture" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="layer-extractor" vertex="1">
                    <mxGeometry x="420" y="62" width="500" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="ex-regex" value="RegexExtractor&#xa;Bounded regex over a sliding window of assembled text. The regex must be anchored or bounded (no unbounded .*) — engine rejects regexes that could exhibit catastrophic backtracking on the window size.&#xa;&#xa;use cases: PII (CC, SSN, email, phone), secret-key formats, content-policy patterns" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="layer-extractor" vertex="1">
                    <mxGeometry x="940" y="62" width="500" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="ex-jsonpath" value="JsonPathExtractor&#xa;For JSON-mode responses (L4 JsonChunkCodec output). Picks a specific field out of the parsed JSON value.&#xa;&#xa;use cases: hide a reasoning field; capture model name; extract metadata; redact specific JSON paths" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="layer-extractor" vertex="1">
                    <mxGeometry x="1460" y="62" width="500" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="ex-classifier" value="ClassifierExtractor (async)&#xa;Calls an out-of-band classifier (small model, regex set, heuristic) on the buffered window. Verdict drives the decision.&#xa;Only async specialization; pays latency on classify, composes with sync CacheAndRelease.&#xa;&#xa;use cases: model-driven safety review; semantic redaction; topic-classifier-gated forwarding" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;dashed=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="layer-extractor" vertex="1">
                    <mxGeometry x="420" y="202" width="500" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="ex-generic" value="Generic mode — impl Extractor yourself&#xa;For cases that don&#39;t fit the four specialized extractors, the trait is the contract; specialized extractors are conveniences. Compose a custom Extractor with a custom (or default Bounded) CacheAndRelease.&#xa;&#xa;Example: a streaming JSON-LD parser that emits Captured events when it sees a new @context block." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;dashed=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="layer-extractor" vertex="1">
                    <mxGeometry x="940" y="202" width="1020" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="layer-comp" value="Composition — Codecs and Transforms compose CacheAndRelease + (optional) Extractor" style="swimlane;startSize=28;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;horizontal=1" parent="1" vertex="1">
                    <mxGeometry x="40" y="960" width="2000" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="comp-codec-title" value="Codecs (015 L2/L4/L5) — when decoding multi-event structures" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1" parent="layer-comp" vertex="1">
                    <mxGeometry x="20" y="38" width="500" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="comp-codec-sse" value="SseFrameCodec (L4)&#xa;CacheAndRelease&lt;Bytes&gt; — buffers body chunks until \n\n terminator. policy: max_bytes=8MB, max_wall_ms=30s, on_overflow=ReleaseVerbatim+audit." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="layer-comp" vertex="1">
                    <mxGeometry x="20" y="62" width="480" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="comp-codec-vendor" value="AnthropicStreamingDecoder (L5)&#xa;CacheAndRelease&lt;BodyFrameEvent&gt; — buffers event:+data: pair. policy: max_bytes=64KB, max_wall_ms=10s, on_overflow=DropAndAudit." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="layer-comp" vertex="1">
                    <mxGeometry x="520" y="62" width="480" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="comp-tx-title" value="Transforms (015 inspectors) — when the decision logic is the value" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1" parent="layer-comp" vertex="1">
                    <mxGeometry x="1020" y="38" width="600" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="comp-tx-marker" value="MarkerScannerTransform (L5, response)&#xa;CacheAndRelease&lt;NormalizedEvent&gt; + LiteralPatternExtractor(&lt;noodle:*&gt;).&#xa;Emits Artifact{name, value} on capture; strips matched range from forwarded stream." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="layer-comp" vertex="1">
                    <mxGeometry x="1020" y="62" width="480" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="comp-tx-pii" value="PiiRedactor (L5, response)  future&#xa;CacheAndRelease&lt;NormalizedEvent&gt; (small rolling window) + RegexExtractor(CC/SSN/email).&#xa;Replace match with synthetic [REDACTED:KIND] token; emit Audit." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;dashed=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" parent="layer-comp" vertex="1">
                    <mxGeometry x="1520" y="62" width="460" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="layer-ex" value="Worked examples — same trait, different policy" style="swimlane;startSize=28;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;horizontal=1" parent="1" vertex="1">
                    <mxGeometry x="40" y="1200" width="2000" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="ex-reasoning" value="Strip a multi-line &lt;noodle:reasoning&gt;...500 tokens...&lt;/noodle:reasoning&gt; block&#xa;&#xa;LiteralPatternExtractor(max_value_bytes=32 KB) + Bounded policy:&#xa;  max_bytes=40 KB,  max_wall_ms=60 s,  min_release_chunk=64 B,  on_overflow=ReleaseVerbatim+audit&#xa;&#xa;Memory bounded. Deadline bounded. Streaming preserved at 64-byte chunks of non-matching content.&#xa;Overflow safe — gives up the strip rather than the response." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" parent="layer-ex" vertex="1">
                    <mxGeometry x="20" y="38" width="970" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="ex-pii" value="Redact credit-card numbers split across SSE deltas&#xa;&#xa;RegexExtractor(\b\d{4}[-\s]?\d{4}[-\s]?\d{4}[-\s]?\d{4}\b, max_window=64 B) + Bounded policy:&#xa;  max_bytes=256 B,  max_wall_ms=5 s,  min_release_chunk=32 B,  on_overflow=DropAndAudit&#xa;&#xa;Small rolling window. DropAndAudit on overflow — safer to drop than to leak.&#xa;Replacement: synthetic Token containing [REDACTED:CC]. Audit carries the redacted-but-never-logged fact." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" parent="layer-ex" vertex="1">
                    <mxGeometry x="1010" y="38" width="970" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="ref" value="docs/adrs/016-cache-and-release-primitives.md — full prose spec, migration plan, audit semantics, open questions.   docs/adrs/015-layered-codec-architecture.md §15 — motivating critique." style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;fontStyle=2" parent="1" vertex="1">
                    <mxGeometry x="40" y="1390" width="2000" height="20" as="geometry"/>
                </mxCell>
