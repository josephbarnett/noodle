    <diagram id="016-cache-release" name="016 · CacheAndRelease and Extractor primitives">
        <mxGraphModel dx="2248" dy="1387" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
            <root>
