                <mxCell id="lane-h" value="H · Downstream consumers   (each tails tap.jsonl independently; decodes with noodle-domain types)" style="swimlane;startSize=24;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;horizontal=1" parent="1" vertex="1">
                    <mxGeometry x="240" y="1530" width="1700" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="h-viewer" value="noodle-viewer&#xa;local debug UI&#xa;JsonlTailer → HubService → React UI&#xa;HTTP mode · SSE mode · OODA mode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11" parent="lane-h" vertex="1">
                    <mxGeometry x="20" y="40" width="380" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="h-collector" value="Telemetry shipper&#xa;OTel collector (filelog receiver) ·&#xa;the telemetry backend · vendor SDKs · file archive&#xa;classify content via noodle-domain;&#xa;correlate by turn_id / session_id." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11" parent="lane-h" vertex="1">
                    <mxGeometry x="420" y="40" width="420" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="h-analytics" value="Behaviour and usage analysis&#xa;cohort analysis · prompt-engineering studies&#xa;model-rollout comparisons" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11" parent="lane-h" vertex="1">
                    <mxGeometry x="860" y="40" width="380" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="h-adhoc" value="ad-hoc consumers&#xa;jq · grep · custom scripts&#xa;additional apps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;dashed=1;fontStyle=2;fontSize=11" parent="lane-h" vertex="1">
