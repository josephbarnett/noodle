                <mxCell id="f-framing" value="Append framing&#xa;one JSON object per line" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11" parent="lane-f" vertex="1">
