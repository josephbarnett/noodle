                    <mxGeometry x="1120" y="40" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="g-note" value="The proxy does NOT depend on this crate.&#xa;Consumers decode tap.jsonl into these types." style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#3d5e3d" parent="lane-g" vertex="1">
                    <mxGeometry x="1380" y="40" width="300" height="60" as="geometry"/>
