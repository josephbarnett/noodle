                </mxCell>

                <mxCell id="future-panel" value="Extension points (planned)" style="swimlane;startSize=24;fillColor=#fff4e6;strokeColor=#d79b00;fontStyle=1;fontSize=12;horizontal=1" parent="1" vertex="1">
                    <mxGeometry x="1960" y="80" width="400" height="1140" as="geometry"/>
                </mxCell>
                <mxCell id="fp-watchtower" value="Watchtower (control plane)&#xa;observes tap.jsonl;&#xa;signals per-session decisions through a&#xa;control port on noodle-core.&#xa;&#xa;Attachment points (no new interfaces needed):&#xa;• Header mutation slot at L3 (HeaderRewriter)&#xa;• Body-level model rewrite (ModelRewriter)&#xa;• Sensitive-content redaction (Redactor)&#xa;• Provider translation (asymmetric Codec pair)&#xa;• Cost feedback via audit events." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;dashed=1;fontStyle=2;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" parent="future-panel" vertex="1">
                    <mxGeometry x="20" y="40" width="360" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="fp-declarative" value="DeclarativeCodec&lt;Spec&gt;&#xa;reads vendor codec spec (JSON / YAML / TOML)&#xa;and implements Codec generically.&#xa;&#xa;Adding a new vendor = drop a spec file&#xa;in config/codecs/. No Rust recompile.&#xa;Story 032 (parked); ADR 019 §safe-subset.&#xa;&#xa;Same Spec grammar inverted for request-side&#xa;mutations: JSONPath-keyed Transform.&#xa;Per-vendor session-key extractor:&#xa;which header / body field identifies the session." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;dashed=1;fontStyle=2;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" parent="future-panel" vertex="1">
                    <mxGeometry x="20" y="320" width="360" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="fp-embell" value="Embellishment / identity plane&#xa;Resolves device_id, project_id, model name&#xa;into person / team / org identity.&#xa;Lives outside noodle-core; consumes&#xa;ResolvedRecord from the side-effect sink.&#xa;ADR 022 · story 028 (deferred).&#xa;&#xa;Boundary out of noodle is file-only;&#xa;noodle never speaks OTLP. The OTel collector&#xa;reads via filelog and ships from there." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;dashed=1;fontStyle=2;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" parent="future-panel" vertex="1">
                    <mxGeometry x="20" y="600" width="360" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="fp-quic" value="QUIC / HTTP-3 MITM&#xa;DNS suppression + UDP/443 blackhole today;&#xa;true QUIC MITM is the steady-state target&#xa;(ADR 014).&#xa;&#xa;Linux entry transport (nftables TPROXY)&#xa;follows the same NETransparentProxyProvider&#xa;shape on a different driving adapter." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;dashed=1;fontStyle=2;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" parent="future-panel" vertex="1">
                    <mxGeometry x="20" y="860" width="360" height="220" as="geometry"/>
                </mxCell>

