                </mxCell>
                <mxCell id="f-tap-jsonl" value="tap.jsonl&#xa;one line per HTTP direction (paired by request_id)&#xa;fields: request_id · direction · ts_unix_ms · domain · endpoint · headers ·&#xa;session_id · parent_session_id · turn_id · per-cell correlation ·&#xa;body_in · body_out · extractions" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#ffffff;strokeColor=#b85450;fontStyle=1;fontSize=11;align=center" parent="lane-f" vertex="1">
