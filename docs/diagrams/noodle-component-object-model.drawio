                <mxCell id="g-trust" value="Trust levels · Reminder subtypes&#xa;permission · reversibility&#xa;turn-end signals" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10" parent="lane-g" vertex="1">
                    <mxGeometry x="860" y="40" width="240" height="60" as="geometry"/>
