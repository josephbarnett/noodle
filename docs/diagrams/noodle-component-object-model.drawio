                <mxCell id="f-backpressure" value="Backpressure policy&#xa;bounded queue · drop / block" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11" parent="lane-f" vertex="1">
