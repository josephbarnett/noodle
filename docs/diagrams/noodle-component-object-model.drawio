                <mxCell id="g-capability" value="Capability classes&#xa;PlainTool · SubAgent · Skill · MCP&#xa;CodeExec · WebFetch · FileOp · Memory&#xa;UserAsk · Render · ModeSwitch · Done" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10" parent="lane-g" vertex="1">
