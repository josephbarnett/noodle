                <mxCell id="types-codec" value="trait Codec {&lt;br&gt;&amp;nbsp; &amp;nbsp;type Input;&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;type Output;&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;fn name() -&amp;gt; &amp;amp;&#39;static str;&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;fn matches(probe: &amp;amp;CodecProbe) -&amp;gt; bool;&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;fn open() -&amp;gt; Box;&lt;br&gt;}&lt;br&gt;trait CodecInstance {&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;fn decode(item: Input) -&amp;gt; Vec&lt;output&gt;;&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;fn encode(item: Output) -&amp;gt; Vec&lt;input&gt;;&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;fn flush() -&amp;gt; Vec&lt;output&gt;;&lt;br&gt;}&lt;/output&gt;&lt;/output&gt;" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Courier New;fontSize=10;spacingLeft=8;spacingTop=4" parent="1" vertex="1">
                    <mxGeometry x="352" y="116" width="380" height="166" as="geometry"/>
                </mxCell>
                <mxCell id="types-transform" value="trait Transform {&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;type Event;&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;fn name() -&amp;gt; &amp;amp;&#39;static str;&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;fn open(att: &amp;amp;TransformAttachment) -&amp;gt; Box;&lt;br&gt;}&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;br&gt;&lt;/font&gt;trait TransformInstance {&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;fn apply(event: Event, side: &amp;amp;mut SideChannelTx) -&amp;gt; Vec;&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp; &amp;nbsp;&lt;/span&gt;fn flush(side: &amp;amp;mut SideChannelTx) -&amp;gt; Vec;&lt;br&gt;}&lt;/div&gt;" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Courier New;fontSize=10;spacingLeft=8;spacingTop=4" parent="1" vertex="1">
